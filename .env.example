RESEND_API_KEY=re_din_nøkkel_her

# Supabase
VITE_SUPABASE_URL=https://<prosjekt>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # KUN server-side (Vercel env vars)

# Feide OIDC
VITE_FEIDE_CLIENT_ID=<client-id>               # OK i browser (offentlig)
FEIDE_CLIENT_ID=<client-id>                    # Samme verdi, brukes av serverless-funksjon
FEIDE_CLIENT_SECRET=<client-secret>            # KUN server-side – må ALDRI ha VITE_-prefix
